#include "mbed.h"

int main()
{
    DigitalOut led1(LED1);
    DigitalOut led2(LED2);
    DigitalOut led3(LED3);

    led1 = 0;
    led2 = 0;
    led3 = 0;

    DigitalOut* seq[] = { &led1, &led2, &led3, &led2 };
    const int seq_len = sizeof(seq) / sizeof(seq[0]);

    const auto on_time = 200ms;
    const auto off_time = 200ms;

    while (true) {
        for (int i = 0; i < seq_len; i++) {
            led1 = 0;
            led2 = 0;
            led3 = 0;

            *seq[i] = 1;
            ThisThread::sleep_for(on_time);

            *seq[i] = 0;
            ThisThread::sleep_for(off_time);
        }
    }
}
