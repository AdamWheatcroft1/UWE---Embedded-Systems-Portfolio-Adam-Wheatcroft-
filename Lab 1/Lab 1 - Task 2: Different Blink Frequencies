#include "mbed.h"

int main()
{
    DigitalOut led1(LED1);
    DigitalOut led2(LED2);
    DigitalOut led3(LED3);

    led1 = 0;
    led2 = 0;
    led3 = 0;

    const auto tick = 100ms;
    int count = 0;

    while (true) {

        if (count % 5 == 0) {
            led2 = !led2;
        }

        if (count % 10 == 0) {
            led1 = !led1;
        }

        if (count % 20 == 0) {
            led3 = !led3;
        }

        ThisThread::sleep_for(tick);
        count++;

        if (count >= 20) {
            count = 0;
        }
    }
}
