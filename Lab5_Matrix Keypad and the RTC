#include "mbed.h"
#include "arm_book_lib.h"
#include <cstdio>
#include <cstring>
#include <cstdlib>   
#include <ctime>     

#define NUMBER_OF_KEYS                           4
#define BLINKING_TIME_GAS_ALARM               1000
#define BLINKING_TIME_OVER_TEMP_ALARM          500
#define BLINKING_TIME_GAS_AND_OVER_TEMP_ALARM  100
#define NUMBER_OF_AVG_SAMPLES                   100
#define TIME_INCREMENT_MS                       10
#define DEBOUNCE_KEY_TIME_MS                    40
#define KEYPAD_NUMBER_OF_ROWS                    4
#define KEYPAD_NUMBER_OF_COLS                    4
#define EVENTS_MAX_STORAGE                        5
#define UI_PRINT_PERIOD_MS                      500
#define USE_MQ2_ANALOG                           0
#define BUZZER_OPEN_DRAIN_ACTIVE_LOW             1

typedef enum {
    MATRIX_KEYPAD_SCANNING,
    MATRIX_KEYPAD_DEBOUNCE,
    MATRIX_KEYPAD_KEY_HOLD_PRESSED
} matrixKeypadState_t;

typedef struct alarmEvent5 {
    time_t seconds;
    float tempC;
    float gasPpm;
} alarmEvent5_t;

UnbufferedSerial uartUsb(USBTX, USBRX, 115200);

DigitalIn alarmTestButton(BUTTON1);

AnalogIn lm35(A1);
AnalogIn potentiometer(A0);

#if USE_MQ2_ANALOG
AnalogIn mq2(A2);                 
#else
DigitalIn mq2_d0(PE_12);           
#endif

DigitalOut alarmLed(LED1);
DigitalOut incorrectCodeLed(LED3);
DigitalOut systemBlockedLed(LED2);

#if BUZZER_OPEN_DRAIN_ACTIVE_LOW
DigitalInOut sirenPin(PE_10);
#else
DigitalOut sirenPin(PE_10);
#endif

DigitalOut keypadRowPins[KEYPAD_NUMBER_OF_ROWS] = {PB_3, PB_5, PC_7, PA_15};
DigitalIn  keypadColPins[KEYPAD_NUMBER_OF_COLS] = {PB_12, PB_13, PB_15, PC_6};

bool alarmLatched = OFF;          
bool alarmPromptPrinted = false;  

int accumulatedTimeAlarm = 0;
int accumulatedUiPrintTime = 0;

char str[240] = "";

float tempThresholdC = 30.0f;     
float gasThresholdPpm = 400.0f;   

float lm35TempC = 0.0f;
float gasPpm = 0.0f;

float lm35ReadingsAverage  = 0.0f;
float lm35ReadingsSum      = 0.0f;
float lm35ReadingsArray[NUMBER_OF_AVG_SAMPLES];

int accumulatedDebounceMatrixKeypadTime = 0;
int matrixKeypadCodeIndex = 0;
char matrixKeypadLastKeyPressed = '\0';

char matrixKeypadIndexToCharArray[] = {
    '1','2','3','A',
    '4','5','6','B',
    '7','8','9','C',
    '*','0','#','D',
};

matrixKeypadState_t matrixKeypadState;

bool showKeypadInUart = false;

char codeSequence[NUMBER_OF_KEYS] = {'1','8','0','5'};
char keyPressed[NUMBER_OF_KEYS]   = {'0','0','0','0'};

int numberOfIncorrectCodes = 0;
int numberOfHashKeyReleasedEvents = 0;

alarmEvent5_t alarmEvents[EVENTS_MAX_STORAGE];
int alarmEventsCount = 0;
int alarmEventsHead  = 0;

bool lastThresholdState = false;

void inputsInit();
void outputsInit();

void uartTask();
void availableCommands();

void thresholdsUpdate();
void sensorsUpdate();
void alarmUpdate();
void alarmDeactivationUpdate();
void uiStatusUpdate();

void lm35ReadingsArrayInit();
float analogReadingScaledWithTheLM35Formula(float analogReading);

void matrixKeypadInit();
char matrixKeypadScan();
char matrixKeypadUpdate();
void keypadToUart();

bool areEqual();

void pcSerialComStringWrite(const char* str);
char pcSerialComCharRead();
void pcSerialComStringRead(char* str, int strLength);
void pcSerialComCharWrite(char chr);


void alarmEventAdd(float tempC, float gasPpm);
void alarmEventLogPrint();

void buzzerOn();
void buzzerOff();

int main()
{
    inputsInit();
    outputsInit();

    pcSerialComStringWrite("Main Task 5 running\r\n");
    pcSerialComStringWrite("RTC: 's' set, 't' read\r\n");
    pcSerialComStringWrite("Alarm ON: enter 4 digits then '#'\r\n");
    pcSerialComStringWrite("Alarm OFF: press '#' to show last 5 events\r\n\r\n");

#if USE_MQ2_ANALOG
    pcSerialComStringWrite("MQ-2 mode: ANALOG AO->A2 (0..800)\r\n");
#else
    pcSerialComStringWrite("MQ-2 mode: DIGITAL D0->PE_12 (gas shown 0 or 800)\r\n");
#endif

#if BUZZER_OPEN_DRAIN_ACTIVE_LOW
    pcSerialComStringWrite("Buzzer mode: 5V->buzzer->PE_10 (OpenDrain, active LOW)\r\n\r\n");
#else
    pcSerialComStringWrite("Buzzer mode: PE_10->buzzer->GND (active HIGH)\r\n\r\n");
#endif

    while (true) {

        uartTask();            
        thresholdsUpdate();   

        sensorsUpdate();       

        alarmUpdate();         

        alarmDeactivationUpdate(); 

        keypadToUart();        

        uiStatusUpdate();     

        thread_sleep_for(TIME_INCREMENT_MS);
    }
}

void inputsInit()
{
    alarmTestButton.mode(PullDown);

    matrixKeypadInit();

    lm35ReadingsArrayInit();

    for (int i = 0; i < EVENTS_MAX_STORAGE; i++) {
        alarmEvents[i].seconds = 0;
        alarmEvents[i].tempC = 0.0f;
        alarmEvents[i].gasPpm = 0.0f;
    }
}

void outputsInit()
{
    alarmLed = OFF;
    incorrectCodeLed = OFF;
    systemBlockedLed = OFF;

#if BUZZER_OPEN_DRAIN_ACTIVE_LOW
    sirenPin.mode(OpenDrain);
    buzzerOff();
#else
    sirenPin = 0;
#endif
}

void thresholdsUpdate()
{
    float p = potentiometer.read(); 
    tempThresholdC = 25.0f + p * (37.0f - 25.0f);
    gasThresholdPpm = 0.0f + p * 800.0f;
}

static float mq2AnalogToPpm(float a01)
{
    return a01 * 800.0f;
}

void sensorsUpdate()
{
    static int lm35SampleIndex = 0;

    lm35ReadingsArray[lm35SampleIndex] = lm35.read();
    lm35SampleIndex++;
    if (lm35SampleIndex >= NUMBER_OF_AVG_SAMPLES) lm35SampleIndex = 0;

    lm35ReadingsSum = 0.0f;
    for (int i = 0; i < NUMBER_OF_AVG_SAMPLES; i++) {
        lm35ReadingsSum += lm35ReadingsArray[i];
    }
    lm35ReadingsAverage = lm35ReadingsSum / NUMBER_OF_AVG_SAMPLES;
    lm35TempC = analogReadingScaledWithTheLM35Formula(lm35ReadingsAverage);

#if USE_MQ2_ANALOG
    gasPpm = mq2AnalogToPpm(mq2.read());
#else

    bool gasDetected = (mq2_d0.read() == 0);
    gasPpm = gasDetected ? 800.0f : 0.0f;
#endif
}

void alarmUpdate()
{
    bool tempOver = (lm35TempC > tempThresholdC);
    bool gasOver  = (gasPpm > gasThresholdPpm);

    bool thresholdExceeded = (tempOver || gasOver || alarmTestButton);

    if (!lastThresholdState && thresholdExceeded) {
        alarmLatched = ON;
        alarmPromptPrinted = false;
        alarmEventAdd(lm35TempC, gasPpm);
    }
    lastThresholdState = thresholdExceeded;

    if (alarmLatched) {

        if (!alarmPromptPrinted) {
            pcSerialComStringWrite("Enter 4-Digit Code to Deactivate\r\n");
            alarmPromptPrinted = true;
        }

        buzzerOn();

        accumulatedTimeAlarm += TIME_INCREMENT_MS;

        int blinkPeriod = BLINKING_TIME_GAS_AND_OVER_TEMP_ALARM;
        if (tempOver && gasOver) blinkPeriod = BLINKING_TIME_GAS_AND_OVER_TEMP_ALARM;
        else if (gasOver)        blinkPeriod = BLINKING_TIME_GAS_ALARM;
        else if (tempOver)       blinkPeriod = BLINKING_TIME_OVER_TEMP_ALARM;

        if (accumulatedTimeAlarm >= blinkPeriod) {
            accumulatedTimeAlarm = 0;
            alarmLed = !alarmLed;
        }

    } else {
        alarmLed = OFF;
        buzzerOff();
        accumulatedTimeAlarm = 0;
    }
}

void alarmDeactivationUpdate()
{
    if (numberOfIncorrectCodes >= 5) {
        systemBlockedLed = ON;
        return;
    }

    char keyReleased = matrixKeypadUpdate();
    if (keyReleased == '\0') return;

    if (!alarmLatched) {
        if (keyReleased == '#') {
            alarmEventLogPrint();
        }
        return;
    }

    if (keyReleased != '#') {
        if (keyReleased >= '0' && keyReleased <= '9') {
            keyPressed[matrixKeypadCodeIndex] = keyReleased;
            if (matrixKeypadCodeIndex >= (NUMBER_OF_KEYS - 1)) matrixKeypadCodeIndex = 0;
            else matrixKeypadCodeIndex++;
        }
        return;
    }

    if (incorrectCodeLed) {
        numberOfHashKeyReleasedEvents++;
        if (numberOfHashKeyReleasedEvents >= 2) {
            incorrectCodeLed = OFF;
            numberOfHashKeyReleasedEvents = 0;
            matrixKeypadCodeIndex = 0;
        }
        return;
    }

    if (areEqual()) {
        alarmLatched = OFF;
        alarmLed = OFF;
        buzzerOff();

        incorrectCodeLed = OFF;
        systemBlockedLed = OFF;
        numberOfIncorrectCodes = 0;
        matrixKeypadCodeIndex = 0;

        pcSerialComStringWrite("Alarm deactivated.\r\n");
    } else {
        incorrectCodeLed = ON;
        numberOfIncorrectCodes++;
        pcSerialComStringWrite("Incorrect code.\r\n");
    }
}

void uiStatusUpdate()
{
    accumulatedUiPrintTime += TIME_INCREMENT_MS;
    if (accumulatedUiPrintTime < UI_PRINT_PERIOD_MS) return;
    accumulatedUiPrintTime = 0;

    char line[220];
    sprintf(line,
            "Temp=%.1fC (TH=%.1fC) | Gas=%.0f (TH=%.0f) | Alarm=%s\r\n",
            lm35TempC, tempThresholdC,
            gasPpm, gasThresholdPpm,
            alarmLatched ? "ON" : "OFF");
    pcSerialComStringWrite(line);
}

void uartTask()
{
    char receivedChar = pcSerialComCharRead();
    if (receivedChar == '\0') return;

    switch (receivedChar) {

        case 'k':
        case 'K':
            pcSerialComStringWrite("\r\nButtons pressed at the matrix keypad:\r\n");
            showKeypadInUart = true;
            break;

        case 'q':
        case 'Q':
            pcSerialComStringWrite("\r\nQuit from command 'k'\r\n");
            showKeypadInUart = false;
            break;

        case 's':
        case 'S': {
            struct tm rtcTime;
            char year[5], month[3], day[3], hour[3], minute[3], second[3];

            pcSerialComStringWrite("\r\nType four digits for the current year (YYYY): ");
            pcSerialComStringRead(year, 4);
            rtcTime.tm_year = atoi(year) - 1900;
            pcSerialComStringWrite("\r\n");

            pcSerialComStringWrite("Type two digits for the current month (01-12): ");
            pcSerialComStringRead(month, 2);
            rtcTime.tm_mon  = atoi(month) - 1;
            pcSerialComStringWrite("\r\n");

            pcSerialComStringWrite("Type two digits for the current day (01-31): ");
            pcSerialComStringRead(day, 2);
            rtcTime.tm_mday = atoi(day);
            pcSerialComStringWrite("\r\n");

            pcSerialComStringWrite("Type two digits for the current hour (00-23): ");
            pcSerialComStringRead(hour, 2);
            rtcTime.tm_hour = atoi(hour);
            pcSerialComStringWrite("\r\n");

            pcSerialComStringWrite("Type two digits for the current minutes (00-59): ");
            pcSerialComStringRead(minute, 2);
            rtcTime.tm_min  = atoi(minute);
            pcSerialComStringWrite("\r\n");

            pcSerialComStringWrite("Type two digits for the current seconds (00-59): ");
            pcSerialComStringRead(second, 2);
            rtcTime.tm_sec  = atoi(second);
            pcSerialComStringWrite("\r\n");

            rtcTime.tm_isdst = -1;
            set_time(mktime(&rtcTime));
            pcSerialComStringWrite("Date and time has been set\r\n");
            break;
        }

        case 't':
        case 'T': {
            time_t epochSeconds = time(NULL);
            str[0] = '\0';
            sprintf(str, "Date and Time = %s", ctime(&epochSeconds));
            pcSerialComStringWrite(str);
            pcSerialComStringWrite("\r\n");
            break;
        }

        default:
            availableCommands();
            break;
    }
}

void availableCommands()
{
    pcSerialComStringWrite("Available commands:\r\n");
    pcSerialComStringWrite("Press 'k' to show buttons pressed at the keypad\r\n");
    pcSerialComStringWrite("Press 'q' to quit keypad echo\r\n");
    pcSerialComStringWrite("Press 's' to set RTC\r\n");
    pcSerialComStringWrite("Press 't' to read RTC\r\n\r\n");
}

void matrixKeypadInit()
{
    matrixKeypadState = MATRIX_KEYPAD_SCANNING;
    for (int pinIndex = 0; pinIndex < KEYPAD_NUMBER_OF_COLS; pinIndex++) {
        keypadColPins[pinIndex].mode(PullUp);
    }
}

char matrixKeypadScan()
{
    for (int r = 0; r < KEYPAD_NUMBER_OF_ROWS; r++) {

        for (int i = 0; i < KEYPAD_NUMBER_OF_ROWS; i++) keypadRowPins[i] = ON;
        keypadRowPins[r] = OFF;

        for (int c = 0; c < KEYPAD_NUMBER_OF_COLS; c++) {
            if (keypadColPins[c] == OFF) {
                return matrixKeypadIndexToCharArray[r * KEYPAD_NUMBER_OF_COLS + c];
            }
        }
    }
    return '\0';
}

char matrixKeypadUpdate()
{
    char keyDetected = '\0';
    char keyReleased = '\0';

    switch (matrixKeypadState) {

        case MATRIX_KEYPAD_SCANNING:
            keyDetected = matrixKeypadScan();
            if (keyDetected != '\0') {
                matrixKeypadLastKeyPressed = keyDetected;
                accumulatedDebounceMatrixKeypadTime = 0;
                matrixKeypadState = MATRIX_KEYPAD_DEBOUNCE;
            }
            break;

        case MATRIX_KEYPAD_DEBOUNCE:
            if (accumulatedDebounceMatrixKeypadTime >= DEBOUNCE_KEY_TIME_MS) {
                keyDetected = matrixKeypadScan();
                if (keyDetected == matrixKeypadLastKeyPressed) {
                    matrixKeypadState = MATRIX_KEYPAD_KEY_HOLD_PRESSED;
                } else {
                    matrixKeypadState = MATRIX_KEYPAD_SCANNING;
                }
            }
            accumulatedDebounceMatrixKeypadTime += TIME_INCREMENT_MS;
            break;

        case MATRIX_KEYPAD_KEY_HOLD_PRESSED:
            keyDetected = matrixKeypadScan();
            if (keyDetected != matrixKeypadLastKeyPressed) {
                if (keyDetected == '\0') {
                    keyReleased = matrixKeypadLastKeyPressed; 
                }
                matrixKeypadState = MATRIX_KEYPAD_SCANNING;
            }
            break;

        default:
            matrixKeypadInit();
            break;
    }

    return keyReleased;
}

void keypadToUart()
{
    if (showKeypadInUart) {
        int k = matrixKeypadUpdate();
        if (k != 0) pcSerialComCharWrite((char)k);
    }
}

void pcSerialComStringWrite(const char* s)
{
    uartUsb.write(s, strlen(s));
}

char pcSerialComCharRead()
{
    char c = '\0';
    if (uartUsb.readable()) uartUsb.read(&c, 1);
    return c;
}

void pcSerialComStringRead(char* s, int len)
{
    for (int i = 0; i < len; i++) {
        uartUsb.read(&s[i], 1);
        uartUsb.write(&s[i], 1);
    }
    s[len] = '\0';
}

void pcSerialComCharWrite(char chr)
{
    char s[2] = {chr, '\0'};
    uartUsb.write(s, 1);
}

float analogReadingScaledWithTheLM35Formula(float analogReading)
{
    return (analogReading * 3.3f / 0.01f);
}

void lm35ReadingsArrayInit()
{
    for (int i = 0; i < NUMBER_OF_AVG_SAMPLES; i++) {
        lm35ReadingsArray[i] = 0.0f;
    }
}

bool areEqual()
{
    for (int i = 0; i < NUMBER_OF_KEYS; i++) {
        if (codeSequence[i] != keyPressed[i]) return false;
    }
    return true;
}

void alarmEventAdd(float tempC, float gasP)
{
    alarmEvents[alarmEventsHead].seconds = time(NULL);
    alarmEvents[alarmEventsHead].tempC   = tempC;
    alarmEvents[alarmEventsHead].gasPpm  = gasP;

    alarmEventsHead = (alarmEventsHead + 1) % EVENTS_MAX_STORAGE;
    if (alarmEventsCount < EVENTS_MAX_STORAGE) alarmEventsCount++;
}

void alarmEventLogPrint()
{
    pcSerialComStringWrite("\r\n--- Last 5 Alarm Events (most recent first) ---\r\n");
    if (alarmEventsCount == 0) {
        pcSerialComStringWrite("No events stored.\r\n\r\n");
        return;
    }

    for (int i = 0; i < alarmEventsCount; i++) {
        int idx = alarmEventsHead - 1 - i;
        if (idx < 0) idx += EVENTS_MAX_STORAGE;

        char line[240];
        sprintf(line, "%d) Temp=%.1fC  Gas=%.0f  Time=%s",
                i + 1,
                alarmEvents[idx].tempC,
                alarmEvents[idx].gasPpm,
                ctime(&alarmEvents[idx].seconds));
        pcSerialComStringWrite(line);
    }
    pcSerialComStringWrite("\r\n");
}

void buzzerOn()
{
#if BUZZER_OPEN_DRAIN_ACTIVE_LOW
    sirenPin.output();
    sirenPin = LOW;     
#else
    sirenPin = 1;
#endif
}

void buzzerOff()
{
#if BUZZER_OPEN_DRAIN_ACTIVE_LOW
    sirenPin.input();   
#else
    sirenPin = 0;
#endif
}
